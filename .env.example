# Jira connection
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token

# Optional: default filters for summary (foco em tarefas ASSIGNADAS a você, não as que abriu)
# JIRA_PROJECT=PROJ
# JIRA_ASSIGNEE=me          # tarefas atribuídas a você (padrão)
# JIRA_JQL=                 # se preenchido, substitui os filtros acima
# JIRA_DAYS_BACK=7
